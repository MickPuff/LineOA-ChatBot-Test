# Optional
PORT=3000
GEMINI_MODEL=gemini-3.1-flash-lite
MAX_CONTEXT_MESSAGES=24
PROCESSED_EVENT_TTL_SECONDS=86400
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_admin_password
